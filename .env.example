# DataSoko Environment Variables (safe template)
# Copy to .env and replace placeholders. Do not commit real secrets.

# -----------------------------
# App environment
# -----------------------------
APP_ENV=development
LOG_LEVEL=INFO
ADMIN_TOKEN=
SETTINGS_ENCRYPTION_KEY=
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://172.168.100.150:3001

# -----------------------------
# PostgreSQL connection
# Priority: DATABASE_URL (if set) overrides PG* fields
# -----------------------------
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=datasoko
PGUSER=postgres
PGPASSWORD=postgres
PGSSLMODE=prefer

# -----------------------------
# Ingestion / validation settings
# -----------------------------
DEFAULT_CURRENCY=KES
MAX_FILE_SIZE_MB=25
BUSINESS_TIMEZONE=Africa/Nairobi

# -----------------------------
# Integration test (local/CI)
# Set DATABASE_URL to enable tests/test_postgres_integration.py
# Example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datasoko_test
# -----------------------------

# -----------------------------
# Frontend (Next.js admin UI)
# -----------------------------
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3001
FRONTEND_ALLOWED_DEV_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://172.168.100.150:3001
NEXT_PUBLIC_API_BASE_URL=http://172.168.100.150:8001

# -----------------------------
# AI narrator integration
# Use env vars for secrets in production.
# -----------------------------
AI_PROVIDER=azure_openai
AI_MODEL=
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=700
AI_STRICT_JSON_ONLY=true
AI_METRICS_ONLY_FALLBACK=true
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_KEY=
OPENAI_MODEL=

# -----------------------------
# WhatsApp integration
# Secrets should come from env in production. UI write-only secret updates are for internal ops/dev.
# -----------------------------
WHATSAPP_PROVIDER=meta_cloud_api
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_SENDER_DISPLAY_NAME=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_URL=

# -----------------------------
# Admin settings defaults
# -----------------------------
DEFAULT_BUSINESS_ID=biz_001
REPORT_SCHEDULE_DAY=Friday
REPORT_SCHEDULE_TIME=18:00
